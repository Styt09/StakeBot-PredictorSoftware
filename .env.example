# ALPHA-GATE X safe local environment example
# Copy this file to .env and fill only what you need.
# Never commit real credentials, secrets, or access tokens.

APP_ENV=development
TRADING_MODE=PAPER
ENABLE_LIVE_TRADING=false

DATABASE_URL=
REDIS_URL=

ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_REDIRECT_URL=
ZERODHA_ACCESS_TOKEN=
ZERODHA_USER_ID=

MAX_DAILY_LOSS=1000
MAX_TRADE_LOSS=250
MAX_OPEN_POSITIONS=2
MAX_QTY_PER_ORDER=1
MIN_SIGNAL_CONFIDENCE=70
MIN_RISK_REWARD=1.5

MARKET_TIMEZONE=Asia/Kolkata
LOG_LEVEL=info

# Phase 10 OpenAI read-only AI auditor.
# OPENAI_API_KEY must stay backend-only and must never be committed.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1-mini
OPENAI_AUDITOR_ENABLED=true
OPENAI_AUTOFIX_ENABLED=false
AI_CAN_MODIFY_FILES=false
AI_CAN_PLACE_ORDERS=false
GO_LIVE_ALLOWED=false

# Backward-compatible legacy keys currently used by older parts of the app.
# Keep these false unless a later audited phase explicitly changes them.
LIVE_TRADING_ENABLED=false
MANUAL_LIVE_APPROVAL_REQUIRED=true
REAL_BROKER_ORDER_SUBMIT_ENABLED=false
AUTO_TRADE_ENABLED=false
KILL_SWITCH_ENABLED=false
ZERODHA_INSTRUMENT_DUMP_PATH=data/instruments.csv
LIVE_SYMBOL_WHITELIST=RELIANCE,INFY,TCS,NIFTY,BANKNIFTY,FINNIFTY
MAX_LIVE_ORDER_QTY=1
