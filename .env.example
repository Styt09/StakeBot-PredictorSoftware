APP_ENV=development
TRADING_MODE=PAPER_TRADING
LIVE_TRADING=false

DATABASE_URL=postgresql://user:password@localhost:5432/alpha_gate_x
REDIS_URL=redis://localhost:6379/0

ZERODHA_API_KEY=your_api_key
ZERODHA_API_SECRET=your_api_secret
ZERODHA_REDIRECT_URL=http://localhost:8000/auth/zerodha/callback
ZERODHA_EXPECTED_USER_ID=your_zerodha_user_id

MAX_DAILY_LOSS_PERCENT=1.0
RISK_PER_TRADE_PERCENT=0.5
MAX_TRADES_PER_DAY=5
MAX_ORDER_QUANTITY=10
MAX_OPEN_POSITIONS=2

ENABLE_FIRST_5_MIN_TRADING=false
ENABLE_SWING_TRADING=true
ENABLE_INTRADAY_TRADING=true

# Phase 6 Zerodha live-data / approval-mode safety
ZERODHA_ACCESS_TOKEN=your_access_token
ZERODHA_INSTRUMENT_DUMP_PATH=data/instruments.csv
ENABLE_ZERODHA_WEBSOCKET=false
ENABLE_APPROVAL_REQUIRED=false
REAL_ORDER_PLACEMENT_ENABLED=false

# Phase 9 production hardening
ALPHA_GATE_PROFILE=LOCAL
AUDIT_DB_PATH=./alpha_gate_x_audit.db
LOG_LEVEL=INFO
METRICS_ENABLED=true
